            ax.tick_params(axis='x', rotation=45)
            ax.grid(True, alpha=0.3)
            plt.tight_layout()
            plt.show()

            # Calculate and print outlier information
            data = self.clean_data[param]
            q1 = data.quantile(0.25)
            q3 = data.quantile(0.75)
            iqr = q3 - q1
            lower_bound = q1 - 1.5 * iqr
            upper_bound = q3 + 1.5 * iqr
            outliers = data[(data < lower_bound) | (data > upper_bound)]
            outlier_percentage = (len(outliers) / len(data)) * 100
            print(f"\nOutlier Analysis for {param}:")
            print(f"Q1: {q1:.2f}, Q3: {q3:.2f}, IQR: {iqr:.2f}")
            print(f"Lower Bound: {lower_bound:.2f}, Upper Bound: {upper_bound:.2f}")
            print(f"Number of Outliers: {len(outliers)} ({outlier_percentage:.2f}%)")
            if len(outliers) > 0:
                print(f"Outlier Range: Min {outliers.min():.2f}, Max {outliers.max():.2f}")
            else:
                print("No outliers detected.")
    
    
    def _perform_regression(self, X, y, model, model_name=""):
        """Helper function for common regression operations"""
        model.fit(X, y)
        y_pred = model.predict(X)
        
        metrics = {
            'r2': r2_score(y, y_pred)
        }
        
        # Calculate p-value using statsmodels
        has_constant = any(np.allclose(X[:, i], 1) for i in range(X.shape[1])) if X.ndim > 1 else False
        if has_constant:
            sm_model = sm.OLS(y, X).fit()
        else:
            sm_model = sm.OLS(y, sm.add_constant(X)).fit()
        metrics['p_value'] = sm_model.f_pvalue
        
        if model_name: 
            print(f"{model_name} - R²: {metrics['r2']:.3f}, p-value: {metrics['p_value']:.3e}")
        
        return model, metrics, y_pred
    
    def simple_linear_regression(self, x_var, y_var):
        print(f"\nSimple Linear Regression: {y_var} vs {x_var}")
        
        df = self.clean_data[[x_var, y_var]].dropna()
        X = df[x_var].values.reshape(-1, 1)
        y = df[y_var].values
        
        model, metrics, y_pred = self._perform_regression(
            X, y, LinearRegression()
        )
        print(f"Coefficient: {model.coef_[0]:.4f}, Intercept: {model.intercept_:.4f}, p-value: {metrics['p_value']:.3e}")
        
        # Separate figures: Scatter with fit line
        fig1, ax1 = plt.subplots(figsize=(8, 5))
        
        ax1.scatter(X, y, alpha=0.6, label='Actual', s=5)
        
        # Add fit line
        X_plot = np.linspace(X.min(), X.max(), 100).reshape(-1, 1)
        y_plot = model.predict(X_plot)
        ax1.plot(X_plot, y_plot, 'r-', linewidth=2, label='Fit')
        
        ax1.set_xlabel(x_var)
        ax1.set_ylabel(y_var)
        ax1.set_title(f'Simple Linear Regression\n{y_var} vs {x_var} (Full Data)\nR² = {metrics["r2"]:.3f}, p = {metrics["p_value"]:.3e}')
        ax1.legend()
        ax1.grid(True, alpha=0.3)
        
        plt.tight_layout()
        plt.show()
        
        return model, metrics['r2'], metrics['p_value']
    
    def polynomial_regression(self, x_var, y_var, degrees=[4]):
        print(f"\nPolynomial Regression: {y_var} vs {x_var}")
        
        df = self.may_data[['time', x_var, y_var]].sort_values('time')
        X = df[x_var].values.reshape(-1, 1)
        y = df[y_var].values
        times = df['time'].values
        
        results = {}
        for degree in degrees:
            poly_features = PolynomialFeatures(degree=degree)
            X_poly = poly_features.fit_transform(X)
            
            model, metrics, y_pred = self._perform_regression(
                X_poly, y, LinearRegression(), f"Degree {degree}"
            )
            results[degree] = {'model': model, 'poly_features': poly_features, **metrics}
        
        # Separate figures
        X_plot = np.linspace(X.min(), X.max(), 100).reshape(-1, 1)
        dates_plot = df['time'].min() + pd.to_timedelta(X_plot.flatten(), unit='D')
        for i, degree in enumerate(degrees):
            result = results[degree]
            X_plot_poly = result['poly_features'].transform(X_plot)
            y_plot_pred = result['model'].predict(X_plot_poly)
            
            fig, ax = plt.subplots(figsize=(8, 5))
            ax.scatter(times, y, alpha=0.6, label='Actual', s=5)
            ax.plot(dates_plot, y_plot_pred, 'r-', linewidth=2, label=f'Degree {degree} fit')
            ax.set_xlabel('Time')
            ax.set_ylabel(y_var)
            ax.set_title(f'Polynomial Degree {degree} (May Data)\nR² = {result["r2"]:.3f}, p = {result["p_value"]:.3e}')
            ax.xaxis.set_major_locator(mdates.MonthLocator())
            ax.xaxis.set_major_formatter(mdates.DateFormatter('%Y-%m'))
            ax.legend()
            ax.grid(True, alpha=0.3)
            ax.tick_params(axis='x', rotation=45)
            plt.tight_layout()
            plt.show()
        
        return results
    
    def time_series_regression(self):
        print("\nTIME SERIES REGRESSION\n" + "-" * 40)
    
        df_sorted = self.may_data.sort_values('time').reset_index(drop=True)
        df_sorted['time_numeric'] = (df_sorted['time'] - df_sorted['time'].min()).dt.total_seconds() / 86400.0
    
        results = {}
        
        # Linear trends, each in separate figure
        for param in self.params:
            fig, ax = plt.subplots(figsize=(9, 5))
            
            X = df_sorted['time_numeric'].values.reshape(-1, 1)
            y = df_sorted[param].values
            mask = ~(np.isnan(X.flatten()) | np.isnan(y))
            X, y = X[mask], y[mask]
        
            model = LinearRegression().fit(X, y)
            y_pred = model.predict(X)
        
            r2, slope = r2_score(y, y_pred), model.coef_[0]
            p_value = stats.pearsonr(X.flatten(), y)[1]
        
            trend_direction = "increasing" if slope > 0 else "decreasing"
            significance = "significant" if p_value < 0.05 else "not significant"
        
            print(f"\n{param}: R²={r2:.3f}, Slope={slope:.6f}/day, Trend={trend_direction} ({significance})")
        
            results[param] = {
                'slope': slope, 'r2': r2, 'p_value': p_value,
                'trend': trend_direction, 'significant': p_value < 0.05
            }
        
            ax.scatter(df_sorted['time'][mask], df_sorted[param][mask], alpha=0.6, s=10)
            ax.plot(df_sorted['time'][mask], y_pred, 'r-', linewidth=2, label=f'Trend (R²={r2:.3f})')
            ax.set(xlabel='Time', ylabel=param, title=f'{param} Time Series (May Data)\nSlope: {slope:.4f}/day')
            ax.xaxis.set_major_locator(mdates.MonthLocator())
            ax.xaxis.set_major_formatter(mdates.DateFormatter('%Y-%m'))
            ax.legend()
            ax.grid(True, alpha=0.3)
            ax.tick_params(axis='x', rotation=45)
            
            plt.tight_layout()
            plt.show()
        
        # Additional ARIMA regression (limited to May data only)
        print("\nARIMA REGRESSION (MAY DATA ONLY)\n" + "-" * 40)
        
        may_df = df_sorted  # Since may_data is already May data
        if len(may_df) == 0:
            print("No data available for May. Skipping ARIMA.")
            return results
        
        # Ensure 'time' is datetime
        may_df['time'] = pd.to_datetime(may_df['time'])
        
        # Resample to hourly intervals (changed from '10T' for better computation and daily seasonality capture)
        may_df = may_df.set_index('time')[self.params].resample('1H').mean().reset_index()
        
        # Split into train (days 1-26) and test (day 27)
        train_df = may_df[may_df['time'].dt.day <= 26]
        test_df = may_df[may_df['time'].dt.day == 27]
        
        arima_results = {}
        
        for param in self.params:
            fig, ax = plt.subplots(figsize=(9, 5))
            
            series_train = train_df.set_index('time')[param].dropna()
            series_test = test_df.set_index('time')[param].dropna()
            if len(series_train) < 10:  # Skip if too few data points in train
                print(f"Skipping ARIMA for {param} (May): Insufficient data in training set")
                continue
            
            # Fit ARIMA with order (1,1,1) as a simple example; adjust as needed
            arima_model = sm.tsa.ARIMA(series_train, order=(1,1,1))
            arima_fit = arima_model.fit()
            
