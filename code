    def correlation_analysis(self):
        print("\nCORRELATION ANALYSIS\n" + "-" * 40)
        
        corr_matrix = self.clean_data[self.params].corr()
        print(f"Correlation Matrix:\n{corr_matrix.round(3)}")
        
        plt.figure(figsize=(10, 8))
        sns.heatmap(corr_matrix, annot=True, cmap='RdBu_r', center=0, square=True, fmt='.3f')
        plt.title('Environmental Parameters Correlation Matrix')
        plt.tight_layout()
        plt.show()
        
        # Get correlation pairs in one comprehension
        corr_pairs = [(self.params[i], self.params[j], corr_matrix.iloc[i, j]) 
                     for i in range(len(self.params)) for j in range(i+1, len(self.params))]
        corr_pairs.sort(key=lambda x: abs(x[2]), reverse=True)
        
        print("\nStrongest Correlations:")
        for param1, param2, corr in corr_pairs:
            strength = "Strong" if abs(corr) > 0.7 else "Moderate" if abs(corr) > 0.4 else "Weak"
            direction = "positive" if corr > 0 else "negative"
            print(f"{param1} vs {param2}: {corr:.3f} ({strength} {direction})")
        
        return corr_matrix, corr_pairs
    
