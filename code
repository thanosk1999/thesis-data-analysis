    def check_device_wifi(self, timeout=2):
        """Check WiFi connection status"""
        for server in [("8.8.8.8", 53), ("1.1.1.1", 53)]:
            try:
                socket.create_connection(server, timeout=timeout)
                return True
            except OSError:
                continue
        return False
    
    def get_real_data_point(self, timestamp):
        """Get next data point from the simulation data (May 27, 10 AM onward)"""
        if self.simulation_data is None or len(self.simulation_data) == 0: return None
        
        if self.current_csv_index >= len(self.simulation_data): self.current_csv_index = 0
        
        row = self.simulation_data.iloc[self.current_csv_index].copy()
        row['time'], row['data_source'] = timestamp, 'real'
        
        self.current_csv_index += 1
        return row.to_dict()
    
    def generate_artificial_data_point(self, timestamp):
        """Generate artificial data using SARIMA forecast interpolation"""
        if not self.interp_functions: return None
        
        artificial_point = {'time': timestamp, 'data_source': 'artificial'}
        
        # Map to corresponding historical time (loop if exceeded)
        index = self.current_csv_index % len(self.simulation_data)
        historical_time = self.simulation_data['time'].iloc[index]
        time_num = mdates.date2num(historical_time)
        
        for param in self.params:
            if param in self.interp_functions:
                new_value = self.interp_functions[param](time_num).item()
                # Apply bounds
                if param == 'T(C)': new_value = np.clip(new_value, -60, 60)
                elif param == 'RH(%)': new_value = np.clip(new_value, 0, 100)
                else: new_value = max(0.001, new_value)
                artificial_point[param] = round(new_value, 3)
            else:
                artificial_point[param] = 0.0  # Default if no model
        
        self.current_csv_index += 1
        return artificial_point
    
    def real_time_data_collection(self, duration_minutes=10, interval_seconds=3):
        """Real-time data collection with WiFi-aware switching"""
        print(f"\nSTARTING REAL-TIME DATA COLLECTION")
        print(f"Duration: {duration_minutes} minutes, Interval: {interval_seconds} seconds")
        print(f"Expected data points: {int((duration_minutes * 60) / interval_seconds)}")
        print("\n" + "="*60)
        print("TIME     | WIFI STATUS | DATA SOURCE | SAMPLE VALUES")
        print("="*60)
        
        self.is_collecting = True
        self.collected_data, self.wifi_log = [], []
        
        start_time, end_time = time.time(), time.time() + (duration_minutes * 60)
        collection_count = 0
        
        try:
            while time.time() < end_time and self.is_collecting:
                current_time = datetime.now()
                wifi_connected = self.check_device_wifi()
                
                self.wifi_log.append({
                    'timestamp': current_time,
                    'wifi_connected': wifi_connected,
                    'collection_number': collection_count + 1
                })
                
                if wifi_connected:
                    data_point = self.get_real_data_point(current_time)
                    wifi_status, data_source = "CONNECTED", "REAL (CSV)"
                else:
                    data_point = self.generate_artificial_data_point(current_time)
                    wifi_status, data_source = "DISCONNECTED", "ARTIFICIAL"
                
                if data_point:
                    self.collected_data.append(data_point)
                    collection_count += 1
                    
                    sample_values = f"T:{data_point['T(C)']:.1f}°C, RH:{data_point['RH(%)']:.1f}%, PM2.5:{data_point['PM2.5']:.1f}"
                    print(f"{current_time.strftime('%H:%M:%S')} | {wifi_status:11} | {data_source:11} | {sample_values}")
                
                time.sleep(interval_seconds)
        
        except KeyboardInterrupt:
            print("\nCollection stopped by user")
            self.is_collecting = False
        
        print("="*60)
        print(f"COLLECTION COMPLETED - Total data points: {len(self.collected_data)}")
        
        return self._analyze_collection_results()
    
    def _analyze_collection_results(self):
        """Analyze collected real-time data and WiFi performance"""
        if not self.collected_data:
            print("No data collected")
            return None
        
        df, wifi_df = pd.DataFrame(self.collected_data), pd.DataFrame(self.wifi_log)
        
        # Calculate statistics
        real_count = len(df[df['data_source'] == 'real'])
        artificial_count = len(df[df['data_source'] == 'artificial'])
        total_count = len(df)
        wifi_uptime = len(wifi_df[wifi_df['wifi_connected']]) / len(wifi_df) * 100 if len(wifi_df) > 0 else 0
        
        print(f"\nCOLLECTION ANALYSIS:")
        print("-" * 40)
        print(f"Total data points: {total_count}")
        print(f"Real data points: {real_count} ({real_count/total_count*100:.1f}%)")
        print(f"Artificial data points: {artificial_count} ({artificial_count/total_count*100:.1f}%)")
        print(f"WiFi uptime: {wifi_uptime:.1f}%")
        
        # Data quality comparison
        if real_count > 0 and artificial_count > 0:
            print(f"\nDATA QUALITY COMPARISON:")
            print("-" * 40)
            real_data, artificial_data = df[df['data_source'] == 'real'], df[df['data_source'] == 'artificial']
            
            for param in self.params:
                if len(real_data) > 0 and len(artificial_data) > 0:
                    real_mean, artificial_mean = real_data[param].mean(), artificial_data[param].mean()
                    difference = abs(real_mean - artificial_mean) / real_mean * 100
                    print(f"{param}: Real={real_mean:.2f}, Artificial={artificial_mean:.2f}, Diff={difference:.1f}%")
        
        return df, wifi_df
    
