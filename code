class UnifiedEnvironmentalAnalysisSystem:
    def __init__(self, csv_file_path):
        self.csv_file_path = csv_file_path
        self.may_csv_path = "may_data.csv"
        self.raw_data = None
        self.clean_data = None
        self.may_data = None
        self.simulation_data = None
        self.simulation_start_day = 27
        self.simulation_start_hour = 10
        self.output_dir = self._create_output_directory()
        self.collected_data, self.wifi_log = [], []
        self.is_collecting = False
        self.current_csv_index = 0
        self.params = ['T(C)', 'RH(%)', 'PM2.5', 'PM10', 'PM1.0']
        self.param_labels = ['Temperature (°C)', 'Humidity (%)', 'PM2.5 (μg/m³)', 'PM10 (μg/m³)', 'PM1.0 (μg/m³)']
        self.sarima_models = {}
        self.interp_functions = {}

    def _create_output_directory(self):
         output_dir = 'environmental_analysis_results'
         os.makedirs(output_dir, exist_ok=True)
         return output_dir
    
    def load_and_clean_data(self, verbose=True):
        if verbose: print("LOADING AND CLEANING DATA\n" + "-" * 40)
        
        self.raw_data = pd.read_csv(self.csv_file_path)
        original_count = len(self.raw_data)
        if verbose: print(f"Original records: {original_count:,}")
        
        # Add time features
        self.raw_data['time'] = pd.to_datetime(self.raw_data['time'])
        time_features = ['month', 'date', 'day_of_year', 'hour', 'month_numeric']
        time_methods = [lambda x: x.dt.to_period('M'), lambda x: x.dt.date, 
                       lambda x: x.dt.dayofyear, lambda x: x.dt.hour, lambda x: x.dt.month]
        for feature, method in zip(time_features, time_methods):
            self.raw_data[feature] = method(self.raw_data['time'])
        
        if verbose: print(f"Data spans from {self.raw_data['time'].min()} to {self.raw_data['time'].max()}")
        
        # Apply filters for valid ranges
        self.clean_data = self.raw_data[
            (self.raw_data['T(C)'] >= -60) & (self.raw_data['T(C)'] <= 60) &
            (self.raw_data['RH(%)'] >= 0) & (self.raw_data['RH(%)'] <= 100) &
            (self.raw_data['PM2.5'] >= 0) &
            (self.raw_data['PM10'] >= 0) &
            (self.raw_data['PM1.0'] >= 0)
        ].copy().reset_index(drop=True)
        
        removed_count = original_count - len(self.clean_data)
        if verbose: print(f"Clean records: {len(self.clean_data):,}\nRemoved records: {removed_count:,} ({removed_count/original_count*100:.2f}%)")
        
        # Add time_numeric
        self.clean_data['time_numeric'] = (self.clean_data['time'] - self.clean_data['time'].min()).dt.total_seconds() / 86400.0
        
        return self.clean_data
    
    def load_may_data(self, verbose=True):
        if verbose: print("LOADING MAY DATA\n" + "-" * 40)
        
        may_raw = pd.read_csv(self.may_csv_path)
        original_count = len(may_raw)
        if verbose: print(f"Original records in May data: {original_count:,}")
        
        # Add time features
        may_raw['time'] = pd.to_datetime(may_raw['time'])
        time_features = ['month', 'date', 'day_of_year', 'hour', 'month_numeric']
        time_methods = [lambda x: x.dt.to_period('M'), lambda x: x.dt.date, 
                       lambda x: x.dt.dayofyear, lambda x: x.dt.hour, lambda x: x.dt.month]
        for feature, method in zip(time_features, time_methods):
            may_raw[feature] = method(may_raw['time'])
        
        if verbose: print(f"May data spans from {may_raw['time'].min()} to {may_raw['time'].max()}")
        
        # Apply filters for valid ranges
        self.may_data = may_raw[
            (may_raw['T(C)'] >= -60) & (may_raw['T(C)'] <= 60) &
            (may_raw['RH(%)'] >= 0) & (may_raw['RH(%)'] <= 100) &
            (may_raw['PM2.5'] >= 0) &
            (may_raw['PM10'] >= 0) &
            (may_raw['PM1.0'] >= 0)
        ].copy().reset_index(drop=True)
        
        removed_count = original_count - len(self.may_data)
        if verbose: print(f"Clean records in May data: {len(self.may_data):,}\nRemoved records: {removed_count:,} ({removed_count/original_count*100:.2f}%)")
        
        # Add time_numeric
        self.may_data['time_numeric'] = (self.may_data['time'] - self.may_data['time'].min()).dt.total_seconds() / 86400.0
        
        # Extract simulation data starting from May 27, 10:00 AM
        may_year = self.may_data['time'].min().year
        may_month = self.may_data['time'].min().month
        simulation_start_str = f"{may_year}-{may_month:02d}-{self.simulation_start_day:02d} {self.simulation_start_hour:02d}:00:00"
        simulation_start_time = pd.to_datetime(simulation_start_str)
        self.simulation_data = self.may_data[self.may_data['time'] >= simulation_start_time].sort_values('time').reset_index(drop=True)
        if verbose: print(f"Simulation data starts from {simulation_start_time} with {len(self.simulation_data)} records.")
        
        # Fit SARIMA models on May 1-26 (resampled to 1H) and prepare interpolation functions for forecasts
        may_df_resampled = self.may_data.set_index('time')[self.params].resample('1H').mean().reset_index()
        train_df = may_df_resampled[may_df_resampled['time'].dt.day <= 26]
        
        for param in self.params:
            series_train = train_df.set_index('time')[param].dropna()
            if len(series_train) < 10:
                if verbose: print(f"Skipping SARIMA fit for {param}: Insufficient training data.")
                continue
            
            sarima_model = sm.tsa.SARIMAX(series_train, order=(1,1,1), seasonal_order=(1,1,1,24))
            sarima_fit = sarima_model.fit()
            self.sarima_models[param] = sarima_fit
            
            # Pre-forecast 48 steps (covers May 27 and beyond)
            forecast_steps = 48
            forecast = sarima_fit.forecast(steps=forecast_steps)
            last_time = series_train.index[-1]
            forecast_index = pd.date_range(start=last_time + timedelta(hours=1), periods=forecast_steps, freq='1H')
            
            # Create interpolation function
            x_num = mdates.date2num(forecast_index)
            y = forecast.values
            self.interp_functions[param] = interp1d(x_num, y, kind='linear', fill_value='extrapolate')
            if verbose: print(f"SARIMA model and interp function prepared for {param}.")
        
        return self.may_data
    
    def calculate_statistics(self):
        print("\nCALCULATING COMPREHENSIVE STATISTICS\n" + "-" * 40)
        
        # Calculate all statistics in parallel
        stats_funcs = ['mean', 'median', 'min', 'max', 'std', 'count']
        monthly_stats = {param: self.clean_data.groupby('month')[param].agg(stats_funcs).round(3) 
                        for param in self.params}
        daily_stats = {param: self.clean_data.groupby('date')[param].agg(['mean', 'median', 'min', 'max']).round(3) 
                      for param in self.params}
        
        # Overall statistics using pandas describe + additional metrics
        base_stats = self.clean_data[self.params].describe().T
        additional_stats = pd.DataFrame({
            'IQR': base_stats['75%'] - base_stats['25%'],
            'Skewness': [stats.skew(self.clean_data[param]) for param in self.params],
            'Kurtosis': [stats.kurtosis(self.clean_data[param]) for param in self.params]
        }, index=self.params)
        overall_stats = pd.concat([base_stats, additional_stats], axis=1).round(3)
        
        print(f"Monthly and daily statistics calculated\n\nOverall Statistical Summary:\n{overall_stats}")
        
        # Additional: Print monthly stats table for each parameter in terminal
        print("\nMonthly Statistics for Each Parameter:")
        print("-" * 40)
        for param in self.params:
            print(f"\n{param}:")
            print(monthly_stats[param].to_string())
        
        return monthly_stats, daily_stats, overall_stats
    
